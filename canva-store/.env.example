# ─── Copy this to Railway's "Variables" tab ───────────────────────────────────
# NEVER commit real values to GitHub — keep this file in .gitignore

# Flask
FLASK_SECRET_KEY=replace-with-a-long-random-string-min-32-chars
BASE_URL=https://your-app-name.up.railway.app

# PostgreSQL — auto-injected by Railway when you add the Postgres plugin.
# You do NOT need to set this manually on Railway. For local dev, set it yourself:
# DATABASE_URL=postgresql://user:password@localhost:5432/canva_store

# Oxapay
OXAPAY_MERCHANT_KEY=your-oxapay-merchant-api-key
OXAPAY_WEBHOOK_SECRET=your-oxapay-webhook-secret

# Email delivery (Gmail example — use an App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourstore@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Store branding
STORE_NAME=Journey Map Templates
SUPPORT_EMAIL=support@yourstore.com
